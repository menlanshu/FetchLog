<Window x:Class="FetchLog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FetchLog - Log File Search Tool" Height="1100" Width="960"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Directories Section -->
        <GroupBox Header="Search Directories" Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <Button Name="btnAddDirectory" Content="Add Directory" Click="BtnAddDirectory_Click"/>
                    <Button Name="btnRemoveDirectory" Content="Remove Selected" Click="BtnRemoveDirectory_Click"/>
                    <Button Name="btnClearDirectories" Content="Clear All" Click="BtnClearDirectories_Click"/>
                </StackPanel>

                <!-- Favorites (#13) -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,2">
                    <Label Content="Favorites:" VerticalAlignment="Center" Padding="0,4,4,4"/>
                    <ComboBox Name="cmbFavorites" Width="290" VerticalContentAlignment="Center"
                              ToolTip="Saved favorite directories"/>
                    <Button Name="btnUseFavorite" Content="Add to Search" Width="95" Margin="4,0,0,0"
                            Click="BtnUseFavorite_Click"
                            ToolTip="Add selected favorite to the search list"/>
                    <Button Name="btnAddFavorite" Content="&#9733; Save Current" Width="100" Margin="4,0,0,0"
                            Click="BtnAddFavorite_Click"
                            ToolTip="Save the selected directory in the list above as a favorite"/>
                    <Button Name="btnRemoveFavorite" Content="Remove" Width="65" Margin="4,0,0,0"
                            Click="BtnRemoveFavorite_Click"
                            ToolTip="Remove selected favorite from saved list"/>
                </WrapPanel>

                <!-- Drag and drop support (#14) -->
                <ListBox Name="lstDirectories" Grid.Row="2" Margin="5"
                         AllowDrop="True"
                         DragEnter="LstDirectories_DragEnter"
                         DragOver="LstDirectories_DragEnter"
                         Drop="LstDirectories_Drop"
                         ToolTip="You can also drag and drop folders here from Windows Explorer"/>
            </Grid>
        </GroupBox>

        <!-- Filter Options Section -->
        <GroupBox Header="Filter Options" Grid.Row="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="File Extensions:" Grid.Row="0" Grid.Column="0"/>
                <TextBox Name="txtFileExtensions" Grid.Row="0" Grid.Column="1"
                         ToolTip="Enter file extensions separated by comma (e.g., .log,.txt) or leave empty for all files"/>

                <Label Content="Include Patterns:" Grid.Row="1" Grid.Column="0"/>
                <TextBox Name="txtIncludePatterns" Grid.Row="1" Grid.Column="1"
                         ToolTip="File name patterns to include, separated by comma (e.g., error*,*debug*)"/>

                <Label Content="Exclude Patterns:" Grid.Row="2" Grid.Column="0"/>
                <TextBox Name="txtExcludePatterns" Grid.Row="2" Grid.Column="1"
                         ToolTip="File name patterns to exclude, separated by comma (e.g., temp*,*.bak)"/>

                <!-- Content Filter + Min Match Count inline (#9, #10) -->
                <Label Content="Content Filter:" Grid.Row="3" Grid.Column="0"/>
                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Name="txtContentFilter" Grid.Column="0"
                             ToolTip="Search for files containing this text or regex pattern"/>
                    <Label Content="Min hits:" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,4,0"
                           ToolTip="Only include files with at least this many matches (requires Content Filter)"/>
                    <TextBox Name="txtMinMatchCount" Grid.Column="2"
                             ToolTip="Minimum number of content matches required (blank = no minimum)"/>
                </Grid>

                <!-- File Size Filter -->
                <Label Content="File Size:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                <Grid Grid.Row="4" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Name="chkSizeFilter" Content="Min:" Grid.Column="0"
                              VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="ChkSizeFilter_Changed" Unchecked="ChkSizeFilter_Changed"
                              ToolTip="Enable file size filtering"/>
                    <TextBox Name="txtMinSize" Grid.Column="1" IsEnabled="False" Text=""/>
                    <ComboBox Name="cmbMinSizeUnit" Grid.Column="2" IsEnabled="False" SelectedIndex="1">
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="KB"/>
                        <ComboBoxItem Content="MB"/>
                        <ComboBoxItem Content="GB"/>
                    </ComboBox>
                    <Label Content="Max:" Grid.Column="3" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Name="txtMaxSize" Grid.Column="4" IsEnabled="False" Text=""/>
                    <ComboBox Name="cmbMaxSizeUnit" Grid.Column="5" IsEnabled="False" SelectedIndex="1">
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="KB"/>
                        <ComboBoxItem Content="MB"/>
                        <ComboBoxItem Content="GB"/>
                    </ComboBox>
                </Grid>

                <!-- Date/Time Range Filter -->
                <Label Content="Date Range:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                <Grid Grid.Row="5" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Name="chkDateFilter" Content="From:" Grid.Column="0"
                              VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="ChkDateFilter_Changed" Unchecked="ChkDateFilter_Changed"
                              ToolTip="Enable date/time range filtering"/>
                    <DatePicker Name="dtpDateFrom" Grid.Column="1" IsEnabled="False"/>
                    <Label Content="To:" Grid.Column="2" VerticalAlignment="Center" Margin="6,0,4,0"/>
                    <DatePicker Name="dtpDateTo" Grid.Column="3" IsEnabled="False"/>
                    <Label Content="Filter by:" Grid.Column="4" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox Name="cmbDateMode" Grid.Column="5" IsEnabled="False" SelectedIndex="0">
                        <ComboBoxItem Content="Last Modified"/>
                        <ComboBoxItem Content="Created"/>
                    </ComboBox>
                </Grid>

                <!-- Collection Cap (#15) -->
                <Label Content="Collection Cap:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                <Grid Grid.Row="6" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Name="chkCollectionCap" Content="Max files:" Grid.Column="0"
                              VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="ChkCollectionCap_Changed" Unchecked="ChkCollectionCap_Changed"
                              ToolTip="Limit how many files and/or total size can be collected"/>
                    <TextBox Name="txtMaxFileCount" Grid.Column="1" IsEnabled="False" Text=""
                             ToolTip="Maximum number of files to collect (blank = no limit)"/>
                    <Label Content="Max total size:" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Name="txtMaxTotalSize" Grid.Column="3" IsEnabled="False" Text=""
                             ToolTip="Stop collecting once combined size exceeds this value"/>
                    <ComboBox Name="cmbMaxTotalSizeUnit" Grid.Column="4" IsEnabled="False" SelectedIndex="2">
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="KB"/>
                        <ComboBoxItem Content="MB"/>
                        <ComboBoxItem Content="GB"/>
                    </ComboBox>
                </Grid>

                <!-- Rename on Copy (#16) -->
                <Label Content="Rename on Copy:" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
                <Grid Grid.Row="7" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Name="chkRename" Content="Enable" Grid.Column="0"
                              VerticalAlignment="Center" Margin="0,0,4,0"
                              Checked="ChkRename_Changed" Unchecked="ChkRename_Changed"
                              ToolTip="Add a prefix and/or suffix to file names when copying"/>
                    <Label Content="Prefix:" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Name="txtRenamePrefix" Grid.Column="2" IsEnabled="False"
                             ToolTip="Text to prepend to the file name (e.g. BACKUP_)"/>
                    <Label Content="Suffix:" Grid.Column="3" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Name="txtRenameSuffix" Grid.Column="4" IsEnabled="False"
                             ToolTip="Text to insert before the extension (e.g. _old)"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Search Options Section -->
        <GroupBox Header="Search Options" Grid.Row="2" Padding="10" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal">
                <CheckBox Name="chkRecursive" Content="Search subdirectories recursively" IsChecked="True" Margin="0,0,16,2"/>
                <CheckBox Name="chkSearchInZip" Content="Search inside ZIP, 7z, TAR &amp; RAR files" IsChecked="True" Margin="0,0,16,2"
                          ToolTip="Search inside ZIP, 7z, TAR, TAR.GZ, TAR.BZ2 and RAR archives (#18)"/>
                <CheckBox Name="chkCaseSensitive" Content="Case-sensitive content search" IsChecked="False" Margin="0,0,16,2"/>
                <CheckBox Name="chkUseRegex" Content="Use regex for content search" IsChecked="False" Margin="0,0,16,2"
                          ToolTip="Treat the Content Filter as a .NET regex pattern (e.g. ERROR\s+\d{4}-\d{2}-\d{2})"/>
                <CheckBox Name="chkMultilineSearch" Content="Multiline regex (dot matches newline)" IsChecked="False" Margin="0,0,16,2"
                          ToolTip="In regex mode: makes '.' match newline so patterns can span lines (e.g. START.*END across lines)"/>
                <CheckBox Name="chkCompressOutput" Content="Compress output to ZIP archive" IsChecked="False" Margin="0,0,16,2"
                          ToolTip="Bundle all matched files into a timestamped ZIP in the output folder"/>
                <CheckBox Name="chkPreserveStructure" Content="Preserve directory structure in output" IsChecked="False"
                          ToolTip="Mirror the original folder hierarchy under the output directory"/>
                <CheckBox Name="chkIncrementalSearch" Content="Show results as found" IsChecked="True" Margin="0,0,16,2"
                          ToolTip="Stream each result to the list immediately as it is found (#21)"/>
                <CheckBox Name="chkDetectDuplicates" Content="Detect duplicate files" IsChecked="False" Margin="0,0,16,2"
                          ToolTip="After search, identify files with identical content (MD5 hash). Duplicates are highlighted in orange. (#19)"/>
                <CheckBox Name="chkShowFileHash" Content="Show MD5 hash" IsChecked="False" Margin="0,0,16,2"
                          ToolTip="Compute and display the MD5 checksum of each found file in the Hash column (#20)"/>
                <CheckBox Name="chkDetectLogFormat" Content="Detect log format" IsChecked="False"
                          ToolTip="Classify each file as Apache, Syslog, Log4j, JSON, CSV, etc. and show in the Format column (#22)"/>
            </WrapPanel>
        </GroupBox>

        <!-- Output Location + Profiles + History -->
        <GroupBox Header="Output Location" Grid.Row="3" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="txtOutputPath" Grid.Row="0" Grid.Column="0" IsReadOnly="True"/>
                <Button Name="btnBrowseOutput" Content="Browse..." Grid.Row="0" Grid.Column="1" Click="BtnBrowseOutput_Click"/>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0" Orientation="Horizontal">
                    <Label Content="Profiles:" VerticalAlignment="Center" Padding="0,4,4,4"/>
                    <Button Name="btnSaveProfile" Content="Save Profile" Width="95" Click="BtnSaveProfile_Click"
                            ToolTip="Save current search settings to a reusable profile file"/>
                    <Button Name="btnLoadProfile" Content="Load Profile" Width="95" Click="BtnLoadProfile_Click"
                            Margin="4,0,0,0" ToolTip="Load a previously saved profile"/>
                    <Separator Width="1" Background="#BBB" Margin="12,2,12,2"/>
                    <Label Content="History:" VerticalAlignment="Center" Padding="0,4,4,4"/>
                    <ComboBox Name="cmbHistory" Width="240" DisplayMemberPath="Label"
                              ToolTip="Recent searches — select one then click Load"
                              VerticalContentAlignment="Center"/>
                    <Button Name="btnLoadHistory" Content="Load" Width="50" Click="BtnLoadHistory_Click"
                            Margin="4,0,0,0" ToolTip="Restore selected history entry into the form"/>
                    <Button Name="btnClearHistory" Content="Clear" Width="50" Click="BtnClearHistory_Click"
                            Margin="4,0,0,0" ToolTip="Delete all search history"/>
                </WrapPanel>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Center" Margin="0,8">
            <Button Name="btnSearch" Content="Start Search" Click="BtnSearch_Click" Width="120" Height="35"
                    FontWeight="Bold" Background="#FF4CAF50" Foreground="White"/>
            <Button Name="btnCancel" Content="Cancel" Click="BtnCancel_Click" Width="100" Height="35"
                    IsEnabled="False"/>
            <Button Name="btnExportResults" Content="Export Results" Click="BtnExportResults_Click" Width="120" Height="35"
                    IsEnabled="False" Margin="10,0,0,0" ToolTip="Export results list to CSV or HTML"/>
        </StackPanel>

        <!-- Statistics Section -->
        <GroupBox Header="Search Statistics" Grid.Row="5" Padding="10" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Search Time:" Grid.Column="0"/>
                <TextBox Name="txtSearchTime" Grid.Column="1" IsReadOnly="True" Text="0.00s"/>
                <Label Content="Files Found:" Grid.Column="2"/>
                <TextBox Name="txtFilesFound" Grid.Column="3" IsReadOnly="True" Text="0"/>
                <Label Content="Files Copied:" Grid.Column="4"/>
                <TextBox Name="txtFilesCopied" Grid.Column="5" IsReadOnly="True" Text="0"/>
                <Label Content="Total Size:" Grid.Column="6"/>
                <TextBox Name="txtTotalSize" Grid.Column="7" IsReadOnly="True" Text="0 B"/>
            </Grid>
        </GroupBox>

        <!-- Results + Preview Section -->
        <GroupBox Header="Search Results" Grid.Row="6" Padding="6" Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="160" MinHeight="60"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Group-by toolbar (#17) -->
                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,4">
                    <Label Content="Group by:" VerticalAlignment="Center" Padding="0,4,4,4"/>
                    <ComboBox Name="cmbGroupBy" Width="130" SelectedIndex="0"
                              SelectionChanged="CmbGroupBy_SelectionChanged"
                              ToolTip="Group the results list by a property">
                        <ComboBoxItem Content="None"/>
                        <ComboBoxItem Content="Extension"/>
                        <ComboBoxItem Content="Directory"/>
                        <ComboBoxItem Content="Date (Month)"/>
                    </ComboBox>
                </WrapPanel>

                <!-- Results list with match columns -->
                <ListView Name="lvResults" Grid.Row="1"
                          SelectionChanged="LvResults_SelectionChanged"
                          MouseDoubleClick="LvResults_MouseDoubleClick"
                          GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                    <!-- Right-click context menu -->
                    <ListView.ContextMenu>
                        <ContextMenu Opened="LvResultsContextMenu_Opened">
                            <MenuItem Name="cmOpenFile"   Header="Open File"               Click="CmOpenFile_Click"/>
                            <MenuItem Name="cmOpenFolder" Header="Open Containing Folder"   Click="CmOpenFolder_Click"/>
                            <Separator/>
                            <MenuItem Name="cmCopyPath"   Header="Copy Full Path"           Click="CmCopyPath_Click"/>
                            <MenuItem Name="cmCopyName"   Header="Copy File Name"           Click="CmCopyName_Click"/>
                            <MenuItem Name="cmCopyHash"   Header="Copy MD5 Hash"            Click="CmCopyHash_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <!-- Highlight duplicate files in light orange (#19) -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                    <Setter Property="ToolTip"
                                            Value="{Binding DuplicateOf, StringFormat='Duplicate of: {0}'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#E8ECF0" Padding="6,3" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="File Name"   Width="148" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Source Path" Width="192" DisplayMemberBinding="{Binding SourcePath}"/>
                            <GridViewColumn Header="Size"        Width="64"  DisplayMemberBinding="{Binding Size}"/>
                            <GridViewColumn Header="Type"        Width="52"  DisplayMemberBinding="{Binding FileType}"/>
                            <GridViewColumn Header="Modified"    Width="125" DisplayMemberBinding="{Binding LastModifiedDisplay}"/>
                            <GridViewColumn Header="Matches"     Width="55"  DisplayMemberBinding="{Binding MatchCountDisplay}"/>
                            <GridViewColumn Header="Line"        Width="40"  DisplayMemberBinding="{Binding FirstMatchLineDisplay}"/>
                            <GridViewColumn Header="Hash (MD5)"  Width="78"  DisplayMemberBinding="{Binding Md5HashShort}"/>
                            <GridViewColumn Header="Format"      Width="70"  DisplayMemberBinding="{Binding LogFormat}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Draggable splitter -->
                <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                              Background="#E0E0E0" ShowsPreview="True" Cursor="SizeNS"/>

                <!-- Preview panel -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Name="txtPreviewHeader" Grid.Row="0" Margin="4,2"
                               FontSize="11" FontStyle="Italic" Foreground="#555"
                               Text="Select a file to preview its content"/>
                    <TextBox Name="txtPreview" Grid.Row="1"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12" Padding="6"
                             Background="#1E1E1E" Foreground="#D4D4D4" BorderThickness="1"
                             BorderBrush="#444"/>
                </Grid>

                <ProgressBar Name="progressBar" Grid.Row="4" Height="18" Margin="2" Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="8" Height="25">
            <StatusBarItem>
                <TextBlock Name="txtStatus" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
